      "pattern": ["cargo", "fmt"],
      "decision": "allow"
    },
    {
      "id": "cargo_clippy",
      "description": "Allow cargo clippy commands",
      "pattern": ["cargo", "clippy"],
      "decision": "allow"
    },
    {
      "id": "just_lint",
      "description": "Allow just lint commands",
      "pattern": ["just", "lint"],
      "decision": "allow"
    },
    {
      "id": "just_format",
      "description": "Allow just format commands",
      "pattern": ["just", "format"],
      "decision": "allow"
    },
    {
      "id": "just_analyze",
      "description": "Allow just analyze commands",
      "pattern": ["just", "analyze"],
      "decision": "allow"
    },
    {
      "id": "just_typecheck",
      "description": "Allow just typecheck commands",
      "pattern": ["just", "typecheck"],
      "decision": "allow"
    },
    {
      "id": "just_check",
      "description": "Allow just check commands",
      "pattern": ["just", "check"],
      "decision": "allow"
    }
